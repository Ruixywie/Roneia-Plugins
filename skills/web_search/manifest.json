{
  "name": "web_search",
  "version": "1.0.0",
  "title": "网页搜索",
  "description": "搜索网络信息，获取网页内容。支持 Tavily 和 DuckDuckGo 双引擎",
  "icon": "search",
  "category": "tool",
  "skill_type": "code",
  "execution_location": "local",
  "dependencies": ["tavily-python>=0.5", "ddgs>=6.0", "requests>=2.28", "beautifulsoup4>=4.12"],
  "import_map": {"beautifulsoup4": "bs4", "tavily-python": "tavily"},
  "permissions": ["network.access"],
  "tools": [
    {
      "name": "search",
      "description": "使用搜索引擎搜索信息",
      "permission": "network.access",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "description": "搜索关键词",
          "required": true
        },
        {
          "name": "num_results",
          "type": "number",
          "description": "返回结果数量",
          "required": false,
          "default": 5
        }
      ]
    },
    {
      "name": "fetch_page",
      "description": "获取网页内容",
      "permission": "network.access",
      "parameters": [
        {
          "name": "url",
          "type": "string",
          "description": "网页 URL",
          "required": true
        },
        {
          "name": "extract_text",
          "type": "boolean",
          "description": "是否只提取文本（去除 HTML 标签）",
          "required": false,
          "default": true
        },
        {
          "name": "max_length",
          "type": "number",
          "description": "最大内容长度",
          "required": false,
          "default": 5000
        }
      ]
    }
  ]
}
