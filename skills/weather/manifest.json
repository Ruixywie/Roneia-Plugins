{
  "name": "weather",
  "version": "1.0.0",
  "title": "天气查询",
  "description": "查询全球城市的实时天气，支持温度、湿度、风速等信息。零依赖，声明式 API 调用",
  "icon": "cloud-sun",
  "category": "tool",
  "skill_type": "api",
  "execution_location": "local",
  "dependencies": [],
  "import_map": {},
  "permissions": [],
  "base_url": "https://api.openweathermap.org/data/2.5",
  "auth": {
    "type": "query_param",
    "param_name": "appid",
    "env_key": "OPENWEATHER_API_KEY"
  },
  "tools": [
    {
      "name": "get_current",
      "description": "获取指定城市的当前天气",
      "endpoint": "/weather",
      "method": "GET",
      "parameters": [
        {
          "name": "city",
          "type": "string",
          "description": "城市名称（英文，如 Beijing）",
          "required": true,
          "mapping": "q"
        },
        {
          "name": "units",
          "type": "string",
          "description": "温度单位: metric(摄氏) / imperial(华氏)",
          "required": false,
          "default": "metric"
        }
      ],
      "extra_params": {"lang": "zh_cn"},
      "response_mapping": {
        "temperature": "$.main.temp",
        "feels_like": "$.main.feels_like",
        "humidity": "$.main.humidity",
        "description": "$.weather[0].description",
        "wind_speed": "$.wind.speed",
        "city_name": "$.name"
      },
      "timeout": 10
    }
  ]
}
